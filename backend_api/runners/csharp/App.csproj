<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <CodePage>65001</CodePage>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <BaseIntermediateOutputPath>/tmp/obj/</BaseIntermediateOutputPath>
    <IntermediateOutputPath>/tmp/obj/</IntermediateOutputPath>
    <MSBuildProjectExtensionsPath>/tmp/obj/</MSBuildProjectExtensionsPath>
    <OutputPath>/tmp/out/</OutputPath>
    <RestorePackagesPath>/tmp/nuget/</RestorePackagesPath>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="/workspace/main.cs" Link="Program.cs" />
  </ItemGroup>
</Project>
